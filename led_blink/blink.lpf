BLOCK RESETPATHS ;
BLOCK ASYNCPATHS ;
SYSCONFIG MASTER_SPI_PORT=ENABLE MCCLK_FREQ=62 ;

# Clock — 12 MHz from FTDI (JP2 installed, USB connected)
LOCATE COMP "clk" SITE "A10" ;
IOBUF PORT "clk" IO_TYPE=LVCMOS33 ;
FREQUENCY NET "clk" 12.000000 MHz ;

# Reset — SW4, active-low
LOCATE COMP "rstn" SITE "P4" ;
IOBUF PORT "rstn" IO_TYPE=LVCMOS33 ;

# External LEDs — active-high, Bank 1 LVCMOS33
# Schematic: D1=P16, D2=M13, D0=R16, D3=N14
LOCATE COMP "led[0]" SITE "P16" ;  # D1
LOCATE COMP "led[1]" SITE "M13" ;  # D2
LOCATE COMP "led[2]" SITE "R16" ;  # D0
LOCATE COMP "led[3]" SITE "N14" ;  # D3

IOBUF PORT "led[0]" IO_TYPE=LVCMOS33 DRIVE=4 ;
IOBUF PORT "led[1]" IO_TYPE=LVCMOS33 DRIVE=4 ;
IOBUF PORT "led[2]" IO_TYPE=LVCMOS33 DRIVE=4 ;
IOBUF PORT "led[3]" IO_TYPE=LVCMOS33 DRIVE=4 ;
